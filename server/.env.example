# LLM
OPENROUTER_API_KEY=sk-or-...

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=iqbrain
TEMPORAL_TASK_QUEUE=iqbrain-main

# Adapters (mock | teamcenter | sap | ...)
PLM_ADAPTER=mock
ERP_ADAPTER=mock
MES_ADAPTER=mock

# Closure monitoring interval in hours (set low for local dev)
MONITORING_INTERVAL_HOURS=24

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h
# Optional: override default admin account (JSON array)
# AUTH_USERS=[{"username":"alice","password":"secure123","displayName":"Alice"}]

# Server
PORT=3001
NODE_ENV=development
